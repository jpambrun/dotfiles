set unstable

[no-cd]
cleanup:
    find . -name "*Zone.Identifier" -type f -delete

[no-cd]
marimo:
    uv run --no-project --with duckdb,marimo,pyarrow,polars --python 3.11.6  marimo edit  --no-token --headless dash.py

[working-directory: '.config/aquaproj-aqua']
up:
    aqua up

[working-directory: '.config/aquaproj-aqua']
add:
    aqua g -i
