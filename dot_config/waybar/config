{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "network", "pulseaudio", "cpu", "memory", "disk", "battery", "custom/powerprofile", "custom/power"],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "{}"
  },
  "clock": {
    "interval": 1,
    "format": "{:%a %d %b  %H:%M:%S}",
    "tooltip-format": "{:%A, %d %B %Y\nWeek %V}"
  },
  "network": {
    "format-wifi": "net {essid} {signalStrength}%",
    "format-ethernet": "net wired",
    "format-disconnected": "net offline",
    "tooltip-format": "{ifname}: {ipaddr}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "pulseaudio": {
    "format": "vol {volume}%",
    "format-muted": "muted",
    "on-click": "pavucontrol"
  },
  "cpu": {
    "interval": 2,
    "format": "cpu {usage}%"
  },
  "memory": {
    "interval": 2,
    "format": "mem {}%"
  },
  "disk": {
    "interval": 30,
    "path": "/",
    "format": "disk {percentage_used}%"
  },
  "battery": {
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "bat {capacity}%",
    "format-charging": "bat {capacity}% charging",
    "format-plugged": "bat {capacity}% plugged"
  },
  "custom/powerprofile": {
    "interval": 5,
    "exec": "powerprofilesctl get 2>/dev/null || true",
    "format": "profile {}",
    "on-click": "~/.config/sway/scripts/power-profiles"
  },
  "custom/power": {
    "format": "power",
    "on-click": "~/.config/sway/scripts/powermenu"
  }
}
