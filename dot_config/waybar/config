{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,
  "modules-left": ["sway/workspaces", "sway/scratchpad", "sway/mode"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "network", "pulseaudio", "cpu", "temperature", "memory", "custom/powerdraw", "battery", "custom/powerprofile", "custom/power"],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "{}"
  },
  "sway/scratchpad": {
    "format": "scratch {count}",
    "show-empty": false,
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "clock": {
    "interval": 1,
    "format": "{:%a %d %b  %H:%M:%S}",
    "tooltip-format": "{:%A, %d %B %Y\nWeek %V}"
  },
  "network": {
    "format-wifi": "󰤨  {essid} {signalStrength}%",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰤮",
    "tooltip-format": "{ifname}: {ipaddr}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "pulseaudio": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰖁",
    "on-click": "pavucontrol"
  },
  "cpu": {
    "interval": 2,
    "format": "󰻠 {usage}%"
  },
  "memory": {
    "interval": 2,
    "format": "󰍛 {}%"
  },
  "temperature": {
    "interval": 5,
    "critical-threshold": 80,
    "format": "󰔏 {temperatureC}°C"
  },
  "battery": {
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "󰁹 {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%"
  },
  "custom/powerdraw": {
    "interval": 5,
    "exec": "awk '{ printf \"󱐋 %.1fW\", $1 / 1000000 }' /sys/class/power_supply/BAT0/power_now",
    "tooltip": false
  },
  "custom/powerprofile": {
    "interval": 5,
    "exec": "sh -c 'case $(powerprofilesctl get 2>/dev/null) in performance) printf \"󰓅\" ;; balanced) printf \"󰾅\" ;; power-saver) printf \"󰌪\" ;; esac'",
    "format": "{}",
    "on-click": "~/.config/sway/scripts/power-profiles"
  },
  "custom/power": {
    "format": "󰐥",
    "on-click": "~/.config/sway/scripts/powermenu"
  }
}
