# class                 border    bground text      indicator child_border
client.focused          $green    $base   $text     $lavender $lavender
client.focused_inactive $surface2 $base   $subtext1 $sky      $surface2
client.unfocused        $surface2 $base   $subtext1 $blue     $surface2
client.urgent           $peach    $base   $crust    $red      $red
client.placeholder      $surface1 $base   $text     $surface1 $surface1

client.background       $base

bar {
#        mode hide
#        hidden_state hide
        modifier Mod4
        status_command i3blocks -c ~/.config/i3/i3blocks.conf
        #font pango:DejaVu Sans Mono 9
        font pango:Overpass 12
  colors {
    background $base
    statusline $text
    separator  $base

    focused_workspace  $base $mauve $crust
    active_workspace   $base $surface2 $text
    inactive_workspace $base $base $text
    urgent_workspace   $base $red $crust
    binding_mode       $base $peach $crust
  }
}
